# EcoDoc - Muhit o'zgaruvchanlari
# Bu faylni .env nomi bilan nusxa oling va kalitlarni to'ldiring
# IMPORTANT: .env faylini HECH QACHON GitHub'ga yuklamang!

# ==========================================
# TELEGRAM BOT
# ==========================================
# BotFather'dan olingan token
# Qo'llanma: https://t.me/BotFather -> /newbot
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ==========================================
# GROQ API
# ==========================================
# groq.com'dan olingan API kaliti
# Ro'yxatdan o'tish: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# IXTiyoriy SOZLAMALAR
# ==========================================
# Log darajasi (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Hisobotlar saqlanish muddati (kun)
REPORT_RETENTION_DAYS=30
